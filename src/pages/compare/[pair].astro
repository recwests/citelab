---
import Layout from '~/layouts/PageLayout.astro';
import { PAIRS, pairSlug, pairProviders } from '~/data/pairs';
import { loadPrices } from '~/data/loadPrices';

export function getStaticPaths() {
  return PAIRS.map((p) => ({ params: { pair: pairSlug(p) }, props: { pair: p } }));
}

const { pair } = Astro.props as { pair: [string, string] };
const [A, B] = pairProviders(pair);
const prices = loadPrices();
const aRows = prices.filter((r) => r.providerSlug === A.slug).sort((x, y) => x.pricePerHourUsd - y.pricePerHourUsd);
const bRows = prices.filter((r) => r.providerSlug === B.slug).sort((x, y) => x.pricePerHourUsd - y.pricePerHourUsd);

const aMin = aRows[0]?.pricePerHourUsd;
const bMin = bRows[0]?.pricePerHourUsd;
const cheaper = aMin != null && bMin != null ? (aMin <= bMin ? A : B) : null;

const metadata = {
  title: `${A.name} vs ${B.name}: GPU Cloud Price Comparison`,
  description: `Side-by-side $/hour comparison of ${A.name} and ${B.name} GPU cloud pricing for AI training and inference, updated daily.`,
};
---

<Layout metadata={metadata}>
  <section class="px-4 py-12 sm:px-6 mx-auto max-w-4xl">
    <h1 class="text-3xl md:text-4xl font-bold tracking-tight">{A.name} vs {B.name}: which GPU cloud is cheaper?</h1>
    <p class="mt-4 text-lg text-muted">
      {
        cheaper
          ? `On the GPUs both list, ${cheaper.name} has the lower entry price. Compare ${A.name} and ${B.name} on-demand $/hour rates side by side below.`
          : `Compare ${A.name} and ${B.name} on-demand $/hour rates side by side below.`
      }
    </p>

    <div class="grid sm:grid-cols-2 gap-6 mt-8">
      <div>
        <h2 class="text-xl font-semibold">{A.name}</h2>
        <ul class="mt-2 space-y-1">
          {aRows.map((r) => (
            <li class="tabular-nums">{r.gpu}: ${r.pricePerHourUsd.toFixed(2)}/h</li>
          ))}
        </ul>
        <a href={A.affiliateBase} rel="sponsored nofollow" target="_blank" class="inline-block mt-3 text-primary underline">
          Visit {A.name} →
        </a>
      </div>
      <div>
        <h2 class="text-xl font-semibold">{B.name}</h2>
        <ul class="mt-2 space-y-1">
          {bRows.map((r) => (
            <li class="tabular-nums">{r.gpu}: ${r.pricePerHourUsd.toFixed(2)}/h</li>
          ))}
        </ul>
        <a href={B.affiliateBase} rel="sponsored nofollow" target="_blank" class="inline-block mt-3 text-primary underline">
          Visit {B.name} →
        </a>
      </div>
    </div>

    <p class="mt-8 text-sm text-muted">
      See the full <a href="/gpu-cloud-prices" class="underline">GPU cloud price comparison</a> across all providers.
    </p>
  </section>
</Layout>
